{
  "name": "devops-pilot",
  "version": "1.0.0",
  "description": "DevOps Pilot — AI-powered Azure DevOps workstation",
  "author": "Matan Dessaur",
  "license": "AGPL-3.0-only",
  "main": "dashboard/electron-main.js",
  "scripts": {
    "start": "node dashboard/server.js",
    "electron": "electron .",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "@google/gemini-cli": "^0.35.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "playwright-core": "^1.52.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.devops-pilot",
    "productName": "DevOps Pilot",
    "win": {
      "target": "portable",
      "icon": "dashboard/public/icon.png",
      "signAndEditExecutable": false
    },
    "asar": false,
    "npmRebuild": false,
    "files": [
      "dashboard/**/*",
      "config/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}
